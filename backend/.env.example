# ════════════════════════════════════════════════════════
#  COBRANÇAS BACKEND — Configuração
#  Copie este arquivo para .env e preencha os valores
# ════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# URL pública do servidor (usada nos links Pix enviados por WhatsApp/email)
# Em produção: mude para https://seudominio.com.br
BASE_URL=http://localhost:3001

# ── Nome da empresa ───────────────────────────────────
COMPANY_NAME=Minha Empresa
PIX_KEY=pagamentos@minhaempresa.com.br

# ════════════════════════════════════════════════════════
#  🤖 INTELIGÊNCIA ARTIFICIAL (Claude by Anthropic)
#  Obtenha sua chave em: https://console.anthropic.com
#  Custo: ~$0.003 por mensagem gerada (muito barato)
# ════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ════════════════════════════════════════════════════════
#  📱 WHATSAPP — Escolha UM dos provedores abaixo
# ════════════════════════════════════════════════════════

# Opção 1: Z-API (recomendado para Brasil)
# Crie conta em: https://z-api.io
# Plano básico: ~R$50/mês, teste grátis por 5 dias
ZAPI_INSTANCE_ID=your_zapi_instance_id
ZAPI_TOKEN=your_zapi_token
ZAPI_CLIENT_TOKEN=your_zapi_client_token

# Opção 2: Twilio WhatsApp
# Crie conta em: https://twilio.com
# Preço: ~$0.005 por mensagem
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_WHATSAPP_NUMBER=+14155238886

# ════════════════════════════════════════════════════════
#  📧 EMAIL — Escolha UM dos provedores abaixo
# ════════════════════════════════════════════════════════

# Opção 1: Resend (recomendado — 3.000 emails/mês grátis)
# Crie conta em: https://resend.com
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=cobrancas@seudominio.com.br

# Opção 2: Gmail SMTP
# Ative "Senhas de app" em: https://myaccount.google.com/security
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=seu@gmail.com
# EMAIL_PASS=sua_senha_de_app_16_digitos
# EMAIL_FROM=seu@gmail.com

# ════════════════════════════════════════════════════════
#  💳 PIX REAL — Asaas
#  Crie conta em: https://asaas.com
#  Para testes: use sandbox.asaas.com e chave de sandbox
#  Taxa: ~1-2% por transação, sem mensalidade
# ════════════════════════════════════════════════════════
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_SANDBOX=true
# Mude ASAAS_SANDBOX=false em produção
